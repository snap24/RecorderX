<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/bg_main">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Header Section -->
        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECORDER GUIDE"
            android:fontFamily="sans-serif-black"
            android:textColor="@color/accent_lavender"
            android:textSize="18sp"
            android:letterSpacing="0.1"
            android:layout_marginBottom="16dp"/>

        <!-- Scrollable content -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:layout_marginBottom="20dp"
            android:scrollbars="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <!-- CODEC -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VIDEO CODEC"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="H.264 (Most compatible with other players), H.265 (Highly efficient compression), or AV1 (Next-generation high quality)."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- ORIENTATION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ORIENTATION"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Lock recorded video aspect ratios to Auto, Portrait (vertical), or Landscape (horizontal)."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- RESOLUTION -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="RESOLUTION"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="NATIVE captures at your screen\'s exact resolution. 4K, 2K, FHD, HD, and SD lock capture to standard dimensions."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- FRAME RATE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FRAME RATE"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Range of 24-60 FPS for standard video smoothness. High refresh rate devices support 90-120 FPS for ultra-smooth gaming playback."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- BITRATE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BITRATE"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Specifies data speed in Mbps. Higher values capture sharper details during movement but result in larger video files."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- BITRATE MODE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BITRATE MODE"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="VBR (Variable Bitrate) dynamically scales data rate to save storage. CBR (Constant Bitrate) forces high details regardless of movement."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- AUDIO SOURCE -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUDIO SOURCE"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Choose from Silence (OFF), Microphone (MIC), System Internal Loopback (SYS), or MIX (SYS+MIC) to record both together."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

                <!-- AUDIO QUALITY -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="AUDIO QUALITY"
                        android:fontFamily="sans-serif-black"
                        android:textColor="@color/accent_lavender"
                        android:textSize="11sp"
                        android:letterSpacing="0.05"/>
                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Adjust audio sample rate and encoding bitrate. Higher tiers provide cleaner, noise-free sound details."
                        android:textColor="@color/text_primary"
                        android:textSize="13sp"
                        android:fontFamily="sans-serif"
                        android:layout_marginTop="4dp" />
                </LinearLayout>

            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <!-- Dismiss Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnUnderstood"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="UNDERSTOOD"
            android:textColor="@color/black"
            android:textSize="14sp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.05"
            app:backgroundTint="@color/accent_lavender"
            app:cornerRadius="4dp"
            android:elevation="0dp" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
