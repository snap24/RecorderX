<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_amoled"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_amoled"
        app:elevation="0dp">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginTop="16dp"
            android:paddingHorizontal="24dp">

            <TextView
                android:id="@+id/titleMain"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="RECORDER X"
                android:fontFamily="sans-serif-black"
                android:textColor="@color/accent_lavender"
                android:textSize="18sp"
                android:letterSpacing="0.1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saved in: /Movies/RecorderX"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="monospace"
                app:layout_constraintStart_toStartOf="@id/titleMain"
                app:layout_constraintTop_toBottomOf="@id/titleMain" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnViewSource"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SOURCE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnGuide"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GUIDE"
                android:textColor="@color/text_secondary"
                android:textSize="10sp"
                android:fontFamily="sans-serif-black"
                android:layout_marginEnd="4dp"
                app:layout_constraintEnd_toStartOf="@id/btnViewSource"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        android:clipToPadding="false"
        android:paddingBottom="140dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIDEO SUBSYSTEM" android:fontFamily="sans-serif-black" android:textSize="11sp" android:textColor="@color/accent_lavender" android:letterSpacing="0.2" android:layout_marginBottom="24dp"/>

            <!-- Video Codec -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VIDEO CODEC" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/codecSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="2" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="32dp">
                <TextView android:id="@+id/c1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="H.264" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/c2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="H.265" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/c3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AV1" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="c1,c2,c3" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Orientation -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="ORIENTATION" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/orientationSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="2" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="32dp">
                <TextView android:id="@+id/o1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUTO" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/o2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="PORT" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/o3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LAND" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="o1,o2,o3" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Resolution -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="RESOLUTION" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/resolutionSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="5" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="32dp">
                <TextView android:id="@+id/r1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="NATIVE" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/r2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4K" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/r3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2K" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/r4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FHD" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/r5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="HD" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/r6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="480" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="r1,r2,r3,r4,r5,r6" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- FPS -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="FRAME RATE" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/fpsSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="4" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="32dp">
                <TextView android:id="@+id/f1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="24" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/f2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="30" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/f3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="60" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/f4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="90" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/f5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="120" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="f1,f2,f3,f4,f5" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bitrate -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BITRATE" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/bitrateSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="5" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="32dp">
                <TextView android:id="@+id/b1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="2M" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/b2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="4M" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/b3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="8M" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/b4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="12M" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/b5" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="20M" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/b6" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="40M" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="b1,b2,b3,b4,b5,b6" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Bitrate Mode -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="BITRATE MODE" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/bitrateModeSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="1" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="48dp">
                <TextView android:id="@+id/m1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="VBR" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/m2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="CBR" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="m1,m2" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUDIO SUBSYSTEM" android:fontFamily="sans-serif-black" android:textSize="11sp" android:textColor="@color/accent_lavender" android:letterSpacing="0.2" android:layout_marginBottom="24dp"/>

            <!-- Audio Source -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUDIO SOURCE" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/audioSlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="3" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="32dp">
                <TextView android:id="@+id/a1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="OFF" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/a2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MIC" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/a3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SYS" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/a4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="SYS+MIC" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="a1,a2,a3,a4" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Audio Quality -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AUDIO QUALITY" android:textSize="12sp" android:textColor="@color/white" android:textStyle="bold" android:layout_marginBottom="8dp"/>
            <com.google.android.material.slider.Slider android:id="@+id/audioQualitySlider" android:layout_width="match_parent" android:layout_height="wrap_content" android:valueFrom="0" android:valueTo="2" android:stepSize="1" app:trackHeight="32dp" app:thumbRadius="10dp" app:thumbColor="@color/white" app:trackColorActive="@color/accent_lavender" app:trackColorInactive="@color/slider_track_inactive" android:layout_marginBottom="4dp"/>
            <androidx.constraintlayout.widget.ConstraintLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingHorizontal="16dp" android:layout_marginBottom="48dp">
                <TextView android:id="@+id/q1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="LOW" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/q2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MID" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <TextView android:id="@+id/q3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="MAX" android:textColor="@color/white" android:textSize="9sp" android:fontFamily="sans-serif-black"/>
                <androidx.constraintlayout.helper.widget.Flow android:layout_width="match_parent" android:layout_height="wrap_content" app:constraint_referenced_ids="q1,q2,q3" app:flow_horizontalStyle="spread_inside" app:layout_constraintTop_toTopOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Custom Naming -->
            <com.google.android.material.textfield.TextInputLayout style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox" android:layout_width="match_parent" android:layout_height="wrap_content" android:textColorHint="@color/text_secondary" app:boxStrokeColor="@color/accent_lavender" app:hintTextColor="@color/accent_lavender" android:hint="OUTPUT TEMPLATE">
                <com.google.android.material.textfield.TextInputEditText android:id="@+id/namingTemplateEditText" android:layout_width="match_parent" android:layout_height="wrap_content" android:inputType="text" android:fontFamily="monospace" android:textSize="12sp" android:textColor="@color/white" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <FrameLayout android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_gravity="bottom" android:background="@color/bg_amoled" android:padding="24dp">
        <com.google.android.material.button.MaterialButton android:id="@+id/btnRecord" android:layout_width="match_parent" android:layout_height="64dp" android:text="@string/start_recording" android:textColor="@color/black" android:textSize="15sp" android:fontFamily="sans-serif-black" android:letterSpacing="0.1" app:backgroundTint="@color/accent_lavender" app:cornerRadius="4dp" android:elevation="0dp" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>